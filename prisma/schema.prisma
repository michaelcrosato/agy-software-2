generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id        String           @id @default(uuid())
  email     String           @unique
  name      String?
  avatarUrl String?
  createdAt DateTime         @default(now())
  questions Question[]       @relation("AssignedUser")
  comments  Comment[]
  approved  ApprovedAnswer[]
}

model SourceDocument {
  id               String        @id @default(uuid())
  title            String
  fileType         String        // "pdf", "docx", "txt", "csv", "xlsx"
  processingStatus String        @default("Pending") // "Pending", "Success", "Failed"
  approvalStatus   String        @default("Draft")   // "Draft", "Approved"
  tags             String?       // comma-separated
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  chunks           SourceChunk[]
}

model SourceChunk {
  id               String         @id @default(uuid())
  text             String
  pageNumber       Int?
  sectionTitle     String?
  chunkIndex       Int
  createdAt        DateTime       @default(now())
  sourceDocumentId String
  sourceDocument   SourceDocument @relation(fields: [sourceDocumentId], references: [id], onDelete: Cascade)
  citations        Citation[]
}

model ResponseProject {
  id                  String     @id @default(uuid())
  name                String
  customerName        String
  dueDate             DateTime?
  status              String     @default("Uploaded") // "Uploaded", "Processing", "In Review", "Completed"
  createdAt           DateTime   @default(now())
  updatedAt           DateTime   @updatedAt
  questions           Question[]
  originalHeadersJson String?    // JSON array of original headers
  mappedAnswerColIdx  Int?       // target answer column index
}

model Question {
  id              String          @id @default(uuid())
  originalText    String
  category        String          @default("General")
  answerType      String          @default("Short Text")
  sourceLocation  String?
  status          String          @default("Drafted") // "Drafted", "Needs Review", "Approved", "Needs Source"
  confidenceLabel String          @default("Low")     // "High", "Medium", "Low", "No Source"
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  
  projectId       String
  project         ResponseProject @relation(fields: [projectId], references: [id], onDelete: Cascade)
  
  assignedUserId  String?
  assignedUser    User?           @relation("AssignedUser", fields: [assignedUserId], references: [id], onDelete: SetNull)
  
  answerDraft     AnswerDraft?
  comments        Comment[]
  originalRowJson String?         // JSON array of original row cells
  rowIndex        Int?            // 0-indexed row number in spreadsheet
}

model AnswerDraft {
  id            String     @id @default(uuid())
  text          String
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  
  questionId    String     @unique
  question      Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  citations     Citation[]
}

model Citation {
  id            String      @id @default(uuid())
  quoteExcerpt  String
  createdAt     DateTime    @default(now())
  
  answerDraftId String
  answerDraft   AnswerDraft @relation(fields: [answerDraftId], references: [id], onDelete: Cascade)
  
  sourceChunkId String
  sourceChunk   SourceChunk @relation(fields: [sourceChunkId], references: [id], onDelete: Cascade)
}

model ApprovedAnswer {
  id                String    @id @default(uuid())
  canonicalQuestion String
  answerText        String
  category          String    @default("General")
  tags              String?   // comma-separated
  createdAt         DateTime  @default(now())
  lastUsedAt        DateTime?
  usageCount        Int       @default(0)
  
  approvedById      String?
  approvedBy        User?     @relation(fields: [approvedById], references: [id], onDelete: SetNull)
}

model Comment {
  id         String   @id @default(uuid())
  body       String
  createdAt  DateTime @default(now())
  
  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}
