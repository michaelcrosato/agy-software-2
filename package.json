{
  "name": "answerflow-ai",
  "version": "0.1.0",
  "private": true,
  "license": "MIT",
  "description": "AnswerFlow AI — B2B RFP/questionnaire answering, run by the AI operations engine",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome lint scripts src",
    "test": "vitest run",
    "verify": "bash scripts/verify.sh",
    "shield": "ts-node scripts/assertion-shield.ts",
    "state": "ts-node scripts/update-state.ts",
    "state:validate": "ts-node scripts/update-state.ts --validate",
    "typecheck": "tsc --noEmit",
    "postinstall": "prisma generate",
    "seed": "prisma db push && tsx prisma/seed.ts",
    "e2e": "playwright install --with-deps --only-shell chromium && playwright test"
  },
  "dependencies": {
    "@prisma/adapter-better-sqlite3": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "react": "19.2.0",
    "react-dom": "19.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.16",
    "@playwright/test": "^1.61.0",
    "@tailwindcss/postcss": "4.3.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.9.3",
    "@types/react": "19.2.0",
    "@types/react-dom": "19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "jsdom": "^29.1.1",
    "prisma": "^7.8.0",
    "shellcheck": "^4.1.0",
    "tailwindcss": "4.3.0",
    "ts-node": "^10.9.2",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vitest": "4.1.8"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "better-sqlite3@12.10.0": true,
    "prisma@7.8.0": true
  }
}
